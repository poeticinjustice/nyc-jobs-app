{
  "name": "nyc-jobs-app",
  "version": "1.0.0",
  "description": "MERN stack application for NYC job listings with user authentication and notes",
  "main": "server/index.js",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build",
    "install-server": "npm install",
    "install-all": "npm run install-server && npm run install-client",
    "test:server": "jest --config jest.config.js --forceExit",
    "test:server:watch": "jest --config jest.config.js --watch --forceExit",
    "test:server:coverage": "jest --config jest.config.js --coverage --forceExit",
    "test:helpers": "jest --config jest.config.js --testPathPattern=helpers --forceExit",
    "test:auth": "jest --config jest.config.js --testPathPattern=auth --forceExit",
    "test:jobs": "jest --config jest.config.js --testPathPattern=jobs --forceExit",
    "test:notes": "jest --config jest.config.js --testPathPattern=notes --forceExit",
    "test:searches": "jest --config jest.config.js --testPathPattern=searches --forceExit",
    "test:dashboard": "jest --config jest.config.js --testPathPattern=dashboard --forceExit",
    "test:middleware": "jest --config jest.config.js --testPathPattern=middleware --forceExit",
    "refresh-jobs": "node server/scripts/refreshJobs.js"
  },
  "keywords": [
    "mern",
    "react",
    "node",
    "mongodb",
    "jobs",
    "nyc"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.3.1",
    "helmet": "^7.0.0",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.5.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
