# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here

# Server Configuration
PORT=8000
NODE_ENV=development

# NYC Jobs API (NYC Open Data - no key required)
NYC_JOBS_API_URL=https://data.cityofnewyork.us/resource/kpav-sd4t.json

# USAJobs API (register at https://developer.usajobs.gov/APIRequest/Index)
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_EMAIL=your_email@example.com
USAJOBS_BASE_URL=https://data.usajobs.gov/api/Search

# Adzuna API (register at https://developer.adzuna.com/)
ADZUNA_APP_ID=1688f23d
ADZUNA_APP_KEY=fa8b2a110c052e9368fb3760cd906cb2
ADZUNA_BASE_URL=https://api.adzuna.com/v1/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5000
